# apps/api reads these (copy to apps/api/.env)
# Local dev: the npm-managed embedded Postgres (`npm run db:serve`, or started
# automatically by `npm run dev` / `npm run db:setup`) serves this URL.
# Production: point at Supabase's pooler URL instead (deployment plan §4.2).
DATABASE_URL="postgresql://hearth:hearth@127.0.0.1:5433/hearth"
# Leave unset to run the assistant in deterministic mock mode
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Optional static bearer token for the REST API (open on localhost when unset)
DEV_BEARER_TOKEN=
# MCP write tools are registered only when true
HEARTH_MCP_ENABLE_WRITE=false
PORT=3001

# ── Supabase auth mode (deployment plan §4.1) ────────────────────────────────
# Setting either flips the API from demo mode to Supabase mode: every request
# must carry a Supabase Auth JWT, mapped/provisioned to an Account.
# HS256 verification (legacy projects: Settings → API → JWT secret):
SUPABASE_JWT_SECRET=
# Or asymmetric-key verification via the project JWKS endpoint:
SUPABASE_URL=

# Shared secret for POST /api/v1/internal/run-daily-jobs (X-Cron-Secret
# header); the endpoint is disabled when unset.
CRON_SECRET=

# Comma-separated allowed CORS origins (defaults to the local Vite dev server)
CORS_ORIGIN=

# Per-account limit on turn-starting chat requests per minute (default 30)
CHAT_RATE_LIMIT_MAX=

# Per-account limit on receipt scans per minute (default 10) — each scan is a
# vision model call when ANTHROPIC_API_KEY is set
RECEIPT_RATE_LIMIT_MAX=

# ── Plaid (account setup §6) ─────────────────────────────────────────────────
# All three must be set together, else the app falls back to the mock Plaid
# adapter (a boot-time warning fires if only some are set). Sandbox for now;
# moving to Production later is the same three vars with new values plus
# flipping PLAID_ENV.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Self-generated (openssl rand -base64 32) — encrypts the Plaid access token
# at rest in Integration.configJson. Not a Plaid-issued value.
INTEGRATION_ENCRYPTION_KEY=
# Minimum minutes between bank imports per account (bank pulls are metered).
# Defaults: 60 with a real bank provider configured, 0 (no cooldown) in mock mode.
HEARTH_IMPORT_COOLDOWN_MINUTES=

# ── Stripe Financial Connections (bank import) ───────────────────────────────
# A second bank-transaction feed alongside Plaid (NOT rent payments). Both must
# be set together, else the app falls back to the mock Stripe FC adapter (a
# boot-time warning fires if only one is set). Test keys (sk_test_/pk_test_)
# use Stripe's test institutions; live mode additionally requires completing
# the Financial Connections registration in the Stripe Dashboard. No
# INTEGRATION_ENCRYPTION_KEY needed: only inert fca_/cus_ ids are stored.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Supabase Storage (document uploads) ──────────────────────────────────────
# SUPABASE_URL (above) + SUPABASE_SERVICE_ROLE_KEY together select the real
# Supabase Storage adapter; partial/absent config falls back to local mock
# storage in apps/api/uploads/ (a boot-time warning fires if only one is set).
# One-time setup: create a PRIVATE bucket in the Supabase dashboard (Storage →
# New bucket) matching SUPABASE_STORAGE_BUCKET.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# ── APNs push notifications (Phase 2 iOS shell; docs/MOBILE.md) ──────────────
# All four identity vars must be set together, else the app falls back to the
# mock push provider (a boot-time warning fires if only some are set).
# APNS_PRIVATE_KEY is the .p8 key contents (PKCS8 PEM) with newlines escaped
# as \n. APNS_ENV must match the install channel: sandbox = Xcode run to
# device, production = TestFlight — a mismatch yields BadDeviceToken and
# prunes valid device rows.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
APNS_ENV=sandbox

# ── apps/web build-time vars (put in apps/web/.env.local) ───────────────────
# Both set → the web app shows the login screen and sends the Supabase session
# token as its bearer token. Unset → demo mode (optional VITE_DEV_BEARER_TOKEN).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_DEV_BEARER_TOKEN=

# Plaid is hidden (not removed) from the Settings integrations list while
# Stripe Financial Connections is the preferred bank feed. Set to "true" to
# resurface the Plaid row; accounts with an already-connected Plaid row see it
# regardless. Build-time (web bundle) — not a Worker/container secret.
# VITE_SHOW_PLAID=
