// ─────────────────────────────────────────────────────────────────────────────
// Hearth schema — PostgreSQL (ARCHITECTURE §2; deployment plan §4.2).
// Local dev/tests run an npm-managed embedded Postgres (scripts/dev-postgres.ts,
// no system install); production points DATABASE_URL at Supabase.
//
// BINDING CONVENTIONS — DO NOT BREAK:
//   • NO Prisma `enum` blocks and NO `Decimal` columns. Enum-like columns are
//     `String` validated by the Zod enums in @hearth/shared (each column
//     carries a comment naming its enum) — @hearth/shared stays the single
//     source of truth; native Postgres enums are deliberately deferred
//     (deployment plan §4.2). Money never uses Decimal:
//   • ALL money is integer cents (`Int`, field suffix `Cents`).
//   • All ids are cuid(). Every root entity carries `accountId`.
//   • Schema changes ship as migrations (`prisma migrate dev --name ...`);
//     `db push` is no longer part of any flow.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // native = the dev machine; the two linux targets cover the Docker image
  // (arm64 for Apple-Silicon local builds, x64 for CI/Cloudflare).
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  timezone            String    @default("America/New_York")
  taxRatePct          Int       @default(20)
  taxYearStartMonth   Int       @default(1)
  graceDays           Int       @default(0)
  // How graceDays is measured (GraceDaysBasis @hearth/shared): 'calendar'
  // (default) counts every day; 'business' counts only Mon–Fri. Threaded
  // alongside timezone everywhere deriveRentStatus is called.
  graceDaysBasis      String    @default("calendar")
  // Account-wide default late fee (integer cents) applied when a landlord marks
  // a late charge (WS7). 0 = late fees disabled account-wide. A Lease may
  // override this (Lease.lateFeeCents). Policy only — never auto-applied.
  defaultLateFeeCents Int       @default(0)
  // Set when the account owner requests deletion (data erasure); the daily
  // scheduler hard-deletes the account once ACCOUNT_DELETION_GRACE_DAYS have
  // elapsed. Clearing this field (a "cancel deletion" action) recovers the
  // account with no data loss during the grace window.
  deletionRequestedAt DateTime?
  createdAt           DateTime  @default(now())

  properties   Property[]
  tenants      Tenant[]
  categories   Category[]
  transactions Transaction[]
  reports      Report[]
  insights     Insight[]
  chatSessions ChatSession[]
  integrations Integration[]
  auditLogs    AuditLog[]
  users        User[]
  invites      Invite[]
  documents    Document[]
  contractors  Contractor[]
  pushDevices  PushDevice[]
  onboarding   OnboardingState?
  vendorCategoryMemories VendorCategoryMemory[]
  bankSyncDiscrepancies  BankSyncDiscrepancy[]
}

// Getting-started checklist state (one row per account, created lazily on the
// first onboarding write). Step completion is derived live from portfolio data
// in onboarding.service — only the user's explicit choices persist here.
model OnboardingState {
  id          String   @id @default(cuid())
  accountId   String   @unique
  status      String   @default("not_started") // OnboardingStatus (@hearth/shared), stored subset: not_started | in_progress | dismissed ("completed" is always derived)
  skippedJson String   @default("[]") // OnboardingStepId[] the user chose to skip
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// Auth principal → Account mapping (deployment plan §4.1). One row per
// external identity; many-users-per-account is supported by design even
// though v1 provisions 1:1. Absent in demo mode (no Supabase configured).
model User {
  id             String   @id @default(cuid())
  accountId      String
  supabaseUserId String   @unique // Supabase Auth `sub` claim
  email          String
  role           String   @default("owner") // UserRole (@hearth/shared): owner | member
  // MemberPermission[] (@hearth/shared) granted to a member — string-array JSON
  // (same convention as Integration.scopesJson; owners hold all implicitly and
  // ignore this field). Read live on every request so a revoked grant applies
  // immediately.
  permissionsJson String   @default("[]")
  createdAt      DateTime @default(now())
  // Consent capture (docs/SECURITY_PRIVACY_AUDIT.md §B5): recorded when this
  // identity accepts the Privacy Policy + Terms of Service at signup.
  // policyConsentVersion identifies *which* version was accepted, since the
  // documents will change over time.
  policyConsentAcceptedAt DateTime?
  policyConsentVersion    String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// Pending team invite (docs/WHATS_NEXT.md §4). The owner invites a teammate by
// email; on that teammate's first authenticated request, resolveAccountForIdentity
// matches a pending invite by email and attaches them to this account (rather
// than provisioning a fresh one), then flips status to 'accepted'. No email is
// sent — the invite is just a matcher keyed on the address the owner entered.
model Invite {
  id              String    @id @default(cuid())
  accountId       String
  email           String
  role            String    @default("member") // UserRole (@hearth/shared)
  permissionsJson String    @default("[]") // MemberPermission[] granted on accept
  status          String    @default("pending") // pending | accepted | revoked
  invitedByUserId String?
  createdAt       DateTime  @default(now())
  acceptedAt      DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
}

model Property {
  id                   String    @id @default(cuid())
  accountId            String
  nickname             String?
  addressLine1         String
  city                 String
  state                String
  zip                  String
  acquisitionDate      DateTime?
  acquisitionCostCents Int?
  notes                String?
  createdAt            DateTime  @default(now())
  archivedAt           DateTime?

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  units        Unit[]
  transactions Transaction[]
  insights     Insight[]

  @@index([accountId])
  @@index([accountId, archivedAt])
}

model Unit {
  id              String  @id @default(cuid())
  propertyId      String
  label           String
  bedrooms        Int?
  bathrooms       Float?
  marketRentCents Int?
  archivedAt      DateTime?

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]

  @@index([propertyId])
}

model Tenant {
  id        String   @id @default(cuid())
  accountId String
  fullName  String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  archivedAt DateTime?

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leaseTenants LeaseTenant[]
  insights     Insight[]
  rentDeposits RentPaymentDeposit[]

  @@index([accountId])
  @@index([accountId, archivedAt])
}

model Lease {
  id              String   @id @default(cuid())
  unitId          String
  rentCents       Int
  dueDay          Int      @default(1)
  // Per-lease late-fee override (WS7). null = fall back to the account default;
  // 0 = explicitly no late fee for this lease even if the account has a default.
  lateFeeCents    Int?
  startDate       DateTime
  endDate         DateTime
  status          String // LeaseStatus (@hearth/shared): active | ended | pending_signature
  esignEnvelopeId String?
  esignStatus     String? // EsignStatus (@hearth/shared): sent | viewed | signed
  createdAt       DateTime @default(now())

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leaseTenants LeaseTenant[]
  rentPayments RentPayment[]
  insights     Insight[]

  @@index([unitId])
}

model LeaseTenant {
  leaseId   String
  tenantId  String
  isPrimary Boolean @default(true)
  // This co-tenant's expected portion of lease.rentCents (plan §C). Null =
  // unspecified — display falls back to an even split. Shares that don't sum
  // to the rent are a soft warning in the UI, never a hard block.
  shareCents Int?

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([leaseId, tenantId])
}

model Category {
  id               String  @id @default(cuid())
  accountId        String? // null = system-seeded
  name             String
  type             String // TransactionType (@hearth/shared): income | expense
  irsScheduleELine String? // e.g. "Line 14 – Repairs"
  isSystem         Boolean @default(false)

  account      Account?      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  vendorCategoryMemories VendorCategoryMemory[]
}

// Per-account vendor → category memory (TRUSTWORTHY_TRANSACTIONS_PLAN.md §A).
// Written when a user corrects (or repeatedly accepts) a category on a
// transaction with a vendor; consulted by suggestCategory before the keyword
// table so corrections stick. vendorKey is the normalized memory key
// (services/vendor.ts vendorMemoryKey — bank-descriptor noise stripped), NOT
// the raw vendor string.
model VendorCategoryMemory {
  id         String   @id @default(cuid())
  accountId  String
  vendorKey  String
  type       String // TransactionType (@hearth/shared): income | expense
  categoryId String
  confidence Float    @default(0.95)
  hitCount   Int      @default(1)
  updatedAt  DateTime @updatedAt

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([accountId, vendorKey, type])
  @@index([accountId])
}

model Transaction {
  id                    String   @id @default(cuid())
  accountId             String
  propertyId            String?
  unitId                String?
  categoryId            String?
  date                  DateTime
  amountCents           Int // always positive; sign comes from `type`
  type                  String // TransactionType (@hearth/shared): income | expense
  description           String
  vendor                String?
  source                String // TransactionSource (@hearth/shared): manual | receipt | bank
  status                String // TransactionStatus (@hearth/shared): pending_review | confirmed | dismissed
  // TransactionClassification (@hearth/shared): transfer | owner_contribution | refund.
  // Null = ordinary row. transfer/owner_contribution are excluded from every
  // P&L/KPI aggregate; refund nets against its expense category (plan §D1).
  classification        String?
  aiSuggestedCategoryId String?
  aiConfidence          Float?
  receiptUrl            String?
  externalId            String? // bank source only: Plaid transaction_id, dedups repeated syncs
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit        Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rentPayment RentPayment?
  rentDeposit RentPaymentDeposit?
  bankSyncDiscrepancies BankSyncDiscrepancy[]

  @@index([accountId, date])
  @@index([accountId, status])
  @@unique([accountId, externalId])
}

// A bank-side change (Plaid/Stripe FC `modified` or `removed`) that arrived
// AFTER the local transaction was confirmed/dismissed. applySyncBatch never
// rewrites a user-vouched row silently, so it records the pending change here
// for the landlord to accept (apply the restated values through the same
// guarded update/remove path so rent-link protections hold) or dismiss (keep
// their version). Keyed loosely on (accountId, externalId, kind) while pending
// so nightly mock-adapter replays refresh a single row in place rather than
// accreting duplicates.
model BankSyncDiscrepancy {
  id            String    @id @default(cuid())
  accountId     String
  // The local ledger row the change targets. SetNull if that row is later
  // deleted by other means — the discrepancy is then only dismissable.
  transactionId String?
  externalId    String    // provider transaction id (matches Transaction.externalId)
  provider      String    // BankSyncProvider (@hearth/shared): plaid | stripe_fc
  kind          String    // BankDiscrepancyKind (@hearth/shared): modified | removed
  bankDataJson  String?   // BankDiscrepancyData (@hearth/shared) for a 'modified' change; null for 'removed'
  status        String    @default("pending") // BankDiscrepancyStatus (@hearth/shared): pending | accepted | dismissed
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([accountId, status])
}

model RentPayment {
  id            String    @id @default(cuid())
  leaseId       String
  period        String // "YYYY-MM"
  dueDate       DateTime // materialized with the month's expected rows; enables exact days-late
  amountCents   Int
  // Running total received (= sum of deposits; maintained inside the same
  // $transaction as every deposit write). 0 < paidCents < amountCents derives
  // the 'partial' display status; stored status stays 'due' until fully paid.
  paidCents     Int       @default(0)
  // Late fee stamped on this charge by an explicit human action (WS7); one fee
  // per charge in v1. 0 = no fee applied. totalDueCents = amountCents +
  // lateFeeCents everywhere the remaining balance is computed; tenant shares
  // stay against the base amountCents. Fee income lands in P&L on a cash basis,
  // via the deposit-created ledger Transaction (categorized 'Late Fees'), not
  // this column.
  lateFeeCents  Int       @default(0)
  method        String? // RentPaymentMethod (@hearth/shared): online | manual | bank — null until paid
  status        String // RentPaymentStatus (@hearth/shared): due | processing | paid | failed
  paidAt        DateTime?
  externalRef   String? // mock Stripe id
  transactionId String?   @unique // legacy single-payment link; deposits are the source of truth
  remindedAt    DateTime?

  lease       Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  // Deleting a linked ledger Transaction is blocked in the service layer
  // (transaction.service.remove) — otherwise SetNull would leave this row
  // status 'paid' with no backing ledger entry. SetNull remains the DB-level
  // fallback for deletes that bypass the service.
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  deposits    RentPaymentDeposit[]

  @@unique([leaseId, period])
  @@index([period])
}

// One received payment toward a RentPayment charge (plan §B2): many deposits
// sum toward one charge, so roommates/partial payers are representable. Every
// deposit is backed 1:1 by a ledger Transaction; RentPayment.paidCents is the
// maintained sum. Deleting a deposit-backed Transaction through the service is
// blocked (transaction.service.remove); the DB-level Cascade covers writes
// that bypass it, and unlinkDeposit is the sanctioned removal path.
model RentPaymentDeposit {
  id            String   @id @default(cuid())
  rentPaymentId String
  transactionId String   @unique
  amountCents   Int
  tenantId      String? // which co-tenant paid (share tracking, plan §C)
  method        String? // RentPaymentMethod (@hearth/shared): online | manual | bank
  paidAt        DateTime @default(now())

  rentPayment RentPayment @relation(fields: [rentPaymentId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([rentPaymentId])
}

// Contractor directory. Usage stats (jobsCount/avgCostCents/lastUsedAt) are
// never stored — they derive at query time from confirmed expense Transactions
// whose vendor matches the contractor name (case/whitespace-insensitive;
// ARCHITECTURE §4).
model Contractor {
  id         String    @id @default(cuid())
  accountId  String
  name       String
  trade      String
  rating     Float? // user-entered 1–5, validated by @hearth/shared
  phone      String?
  email      String?
  website    String? // free text — bare domains allowed; UI prefixes a scheme when linking
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Report {
  id          String   @id @default(cuid())
  accountId   String
  type        String // ReportType (@hearth/shared): balance_sheet | income_statement | pnl | ... | monthly_review
  title       String
  periodStart DateTime
  periodEnd   DateTime
  taxYear     Int?
  propertyId  String? // null = portfolio
  dataJson    String // snapshot — a filed year never silently changes
  generatedAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, type])
}

model Insight {
  id           String   @id @default(cuid())
  accountId    String
  scope        String // InsightScope (@hearth/shared): portfolio | property | tenant
  type         String // rule id: late_rent | expense_spike | renewal_window | underperforming_property
  severity     String // InsightSeverity (@hearth/shared): info | warning | positive
  title        String
  body         String
  actionLabel  String?
  actionTarget String? // frontend route (also the push-notification deep link)
  actionJson   String? // InsightAction (@hearth/shared) — structured executable action; null on pre-action rows
  propertyId   String?
  tenantId     String?
  leaseId      String?
  dedupeKey    String // e.g. "late_rent:t-okafor:2026-07" — dismissal sticks until a new key appears
  status       String // InsightStatus (@hearth/shared): active | dismissed | actioned
  createdAt    DateTime @default(now())

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  lease    Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@unique([accountId, dedupeKey])
  @@index([accountId, status])
}

model ChatSession {
  id                String   @id @default(cuid())
  accountId         String
  title             String?
  status            String // ChatSessionStatus (@hearth/shared): idle | running | awaiting_user
  providerStateJson String? // serialized provider messages[] + pending tool_use_id while awaiting_user
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account  Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([accountId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String // ChatRole (@hearth/shared): user | assistant
  blocksJson String // ContentBlock[] (@hearth/shared chat-blocks)
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Integration {
  id          String   @id @default(cuid())
  accountId   String
  type        String // IntegrationType (@hearth/shared): plaid | stripe | docusign | email | mcp_client
  name        String
  status      String // IntegrationStatus (@hearth/shared): connected | disconnected | mock
  externalRef String?
  scopesJson  String    @default("[]")
  configJson  String    @default("{}") // provider-specific config, e.g. Plaid { accessTokenEncrypted, itemId, cursor }
  lastSyncedAt DateTime? // plaid: last transaction import (display + import cooldown)
  // Nightly-sync health (jobs.service.ts): the scheduler bumps the failure
  // count + stamps the last error on a bank feed that throws, and a later
  // successful sync resets all three. Surfaces the bank_sync_failing insight
  // (>= 3) and the Settings "last sync failed" line.
  lastSyncError    String?
  lastSyncErrorAt  DateTime?
  syncFailureCount Int       @default(0)
  createdAt   DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

// A device registered for push notifications (Phase 2 iOS shell). No userId —
// account is the tenancy boundary, matching every other model. Tokens are
// APNs device tokens; re-registering an existing token reassigns it to the
// authenticated account and bumps lastSeenAt (upsert in push.service).
model PushDevice {
  id         String   @id @default(cuid())
  accountId  String
  platform   String   // PushPlatform (@hearth/shared): ios
  token      String   @unique // APNs device token
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model AuditLog {
  id         String   @id @default(cuid())
  accountId  String
  actor      String // "user" | "ai_suggested_user_confirmed" | "system"
  action     String // e.g. "transaction.created", "rent.reminder_sent", "report.generated", "insight.dismissed"
  entityType String
  entityId   String
  detailJson String?
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
}

// An uploaded file attached to exactly one entity; display context (a lease
// doc showing on its tenants/property) is derived at query time, never stored.
model Document {
  id              String   @id @default(cuid())
  accountId       String
  entityType      String // DocumentEntityType (@hearth/shared): property | unit | tenant | lease | transaction
  entityId        String // no FK — polymorphic; entities soft-archive, never hard-delete
  type            String // DocumentType (@hearth/shared): lease | insurance | receipt | inspection | notice | tax | other
  name            String
  storageKey      String   @unique
  mimeType        String
  sizeBytes       Int
  uploadedByActor String   @default("user") // AuditActor: user | ai_suggested_user_confirmed | system
  createdAt       DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, entityType, entityId])
  @@index([accountId, createdAt])
}

// Proof-of-erasure record (data erasure, docs/SECURITY_PRIVACY_AUDIT.md §B2).
// Deliberately has NO relation to Account: it exists specifically to prove a
// deletion happened *after* the Account row (and everything it cascaded) is
// gone, so it cannot itself carry a foreign key to the thing it's attesting
// was deleted.
model DeletionLog {
  id            String   @id @default(cuid())
  accountId     String // the deleted account's id, kept as a plain string
  accountEmail  String
  requestedAt   DateTime // when the owner requested deletion (grace window start)
  deletedAt     DateTime @default(now())

  @@index([accountId])
}
