{
  "name": "@hearth/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/wait-for-db.ts && tsx watch src/server.ts",
    "build": "tsx scripts/build.ts",
    "start": "node dist/server.js",
    "mcp": "tsx src/mcp/index.ts",
    "db:serve": "tsx scripts/dev-postgres.ts",
    "db:setup": "tsx scripts/db-setup.ts",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@hearth/shared": "*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@prisma/client": "^6.5.0",
    "fastify": "^5.2.0",
    "jose": "^6.2.3",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "embedded-postgres": "^17.10.0-beta.17",
    "esbuild": "^0.28.1",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
